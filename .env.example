# OmniBot — Environment Variable Declarations
#
# This file lists every env key read by the codebase. Local `.env` only
# needs the subset relevant to the developer's setup; CI / production
# must provide the rest. The pre-push config-liveness preflight fails
# if any of these keys appears in code without being declared here.
#
# WARNING: never commit real secrets. Use dev placeholders only.

# === LLM APIs ===
OPENAI_API_KEY=                    # OpenAI / OpenAI-compatible API key
OPENAI_BASE_URL=                   # Override the default OpenAI endpoint
MINIMAX_API_KEY=                   # MiniMax embedding native endpoint
GEMINI_API_KEY=                    # Gemini fallback LLM
FALLBACK_LLM_MODEL=gemini-1.5-flash

# === PostgreSQL ===
DATABASE_URL=                      # postgresql+asyncpg://user:pass@host:port/db

# === Redis ===
REDIS_URL=                         # rediss:// for TLS, redis:// for plain

# === ClamAV ===
CLAMAV_HOST=
CLAMAV_PORT=3310

# === Security ===
JWT_SECRET_KEY=                    # 32+ char HMAC secret
M2M_SECRET_KEY=                    # 32+ char M2M token signing key
IP_WHITELIST_CIDRS=                # CIDR list, comma separated
OMNIBOT_JWT_SECRET=                # alias for JWT_SECRET_KEY (legacy)
OMNIBOT_ADMIN_USER=
OMNIBOT_ADMIN_PASS=

# === Platform webhook verification tokens ===
MESSENGER_VERIFY_TOKEN=            # Facebook Messenger challenge verifier
WHATSAPP_VERIFY_TOKEN=             # WhatsApp Cloud API challenge verifier
A2A_JWKS_URL=                      # A2A JSON Web Key Set endpoint
A2A_AUDIENCE=                      # A2A token `aud` claim

# === Observability ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
PROMETHEUS_PORT=8001

# === App ===
APP_ENV=development
LOG_LEVEL=DEBUG
TESTING=
